<Window x:Class="AIDocAssistant.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:AIDocAssistant.ViewModels"
        xmlns:views="clr-namespace:AIDocAssistant.Views"
        Title="AI Document Assistant" Height="760" Width="1100"
        MinHeight="600" MinWidth="800"
        Background="#0D0D1A" Foreground="#E2E8F0"
        FontFamily="Segoe UI" FontSize="13">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- ── Инверсия Bool → Visibility ── -->
        <Style x:Key="HideWhenBusy" TargetType="FrameworkElement">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- ── Стили кнопок ── -->
        <ControlTemplate x:Key="BtnTpl" TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    CornerRadius="7" Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.85"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.35"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#7C3AED"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Template" Value="{StaticResource BtnTpl}"/>
        </Style>

        <Style x:Key="GhostBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#1E1E35"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
        </Style>

        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#7F1D1D"/>
            <Setter Property="Foreground" Value="#FCA5A5"/>
        </Style>

        <Style x:Key="QuickBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#1A1A2E"/>
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="Padding" Value="10,7"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <!-- ── TextBox ── -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1A1A2E"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="CaretBrush" Value="#7C3AED"/>
            <Setter Property="BorderBrush" Value="#2D2D4E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,9"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <!-- ── ComboBox ── -->
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#1A1A2E"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="BorderBrush" Value="#2D2D4E"/>
            <Setter Property="Padding" Value="10,6"/>
        </Style>

        <!-- ── Разделитель ── -->
        <Style x:Key="Sep" TargetType="Separator">
            <Setter Property="Background" Value="#1E1E35"/>
            <Setter Property="Margin" Value="0,10,0,10"/>
        </Style>

        <!-- ── Заголовок секции (sidebar) ── -->
        <Style x:Key="SideHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <!-- ── Chat templates ── -->
        <DataTemplate x:Key="UserMsgTemplate" DataType="{x:Type vm:ChatMessage}">
            <Grid Margin="48,3,12,3">
                <Border Background="#6D28D9" CornerRadius="14,14,2,14"
                        Padding="13,9" HorizontalAlignment="Right" MaxWidth="520">
                    <TextBlock Text="{Binding Text}" TextWrapping="Wrap"
                               Foreground="White" LineHeight="20"/>
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="AiMsgTemplate" DataType="{x:Type vm:ChatMessage}">
            <Grid Margin="12,3,48,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="30" Height="30" CornerRadius="15"
                        Background="#312E81" VerticalAlignment="Top" Margin="0,2,0,0">
                    <TextBlock Text="AI" Foreground="#A5B4FC" FontSize="10" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border Grid.Column="2" Background="#172032" CornerRadius="2,14,14,14"
                        Padding="13,9" MaxWidth="520" HorizontalAlignment="Left">
                    <TextBlock Text="{Binding Text}" TextWrapping="Wrap"
                               Foreground="#CBD5E1" LineHeight="20"/>
                </Border>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="SysMsgTemplate" DataType="{x:Type vm:ChatMessage}">
            <Grid Margin="12,2">
                <TextBlock Text="{Binding Text}" TextWrapping="Wrap"
                           Foreground="#475569" FontSize="12" LineHeight="18"/>
            </Grid>
        </DataTemplate>

        <!-- Template selector -->
        <views:ChatTemplateSelector x:Key="ChatSel"
            UserTemplate="{StaticResource UserMsgTemplate}"
            AiTemplate="{StaticResource AiMsgTemplate}"
            SystemTemplate="{StaticResource SysMsgTemplate}"/>

        <!-- ProgressBar style -->
        <Style TargetType="ProgressBar">
            <Setter Property="Background" Value="#1A1A2E"/>
            <Setter Property="Foreground" Value="#7C3AED"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="54"/>   <!-- Header -->
            <RowDefinition Height="*"/>    <!-- Content -->
        </Grid.RowDefinitions>

        <!-- ════════════════ HEADER ════════════════ -->
        <Border Grid.Row="0" Background="#12121E" BorderBrush="#1E1E35" BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Статус -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,7,0">
                        <Ellipse.Fill>
                            <SolidColorBrush Color="{Binding ConnectStatusColor}"/>
                        </Ellipse.Fill>
                    </Ellipse>
                    <TextBlock Text="{Binding ConnectStatus}" Foreground="#94A3B8" FontSize="12"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Кнопки -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="📋 История" Style="{StaticResource GhostBtn}"
                            Margin="0,0,8,0" Command="{Binding OpenHistoryCommand}"/>
                    <Button Content="⚙ Настройки" Style="{StaticResource GhostBtn}"
                            Command="{Binding OpenSettingsCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ════════════════ CONTENT ════════════════ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>  <!-- Sidebar -->
                <ColumnDefinition Width="1"/>    <!-- Divider -->
                <ColumnDefinition Width="*"/>    <!-- Chat -->
            </Grid.ColumnDefinitions>

            <!-- Divider -->
            <Border Grid.Column="1" Background="#1E1E35"/>

            <!-- ──────── SIDEBAR ──────── -->
            <Grid Grid.Column="0" Background="#12121E">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>   <!-- Заголовок + Список файлов -->
                    <RowDefinition Height="180"/>    <!-- ListBox -->
                    <RowDefinition Height="*"/>      <!-- Прокручиваемая часть -->
                </Grid.RowDefinitions>

                <!-- Заголовок списка файлов -->
                <Grid Grid.Row="0" Margin="14,14,14,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="ОТКРЫТЫЕ ДОКУМЕНТЫ" Style="{StaticResource SideHeader}" Margin="0"/>
                    <TextBlock Grid.Column="1" Text="{Binding LastRefreshText}" Foreground="#374151"
                               FontSize="9" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <Button Grid.Column="2" Content="↻" VerticalAlignment="Center"
                            Background="Transparent" Foreground="#475569" BorderThickness="0"
                            FontSize="14" Cursor="Hand" Padding="2,0"
                            Command="{Binding RefreshDocsCommand}"
                            ToolTip="Обновить список документов"/>
                </Grid>

                <!-- Список документов Word -->
                <ListBox Grid.Row="1" Margin="14,0,14,4"
                         ItemsSource="{Binding OpenDocuments}"
                         SelectedItem="{Binding SelectedDocument}"
                         SelectionChanged="DocList_SelectionChanged"
                         Background="#0D0D1A" BorderBrush="#1E1E35" BorderThickness="1"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Foreground" Value="#94A3B8"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Padding" Value="10,7"/>
                            <Setter Property="FontSize" Value="12"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}">
                                            <TextBlock Text="{Binding}" TextTrimming="CharacterEllipsis"
                                                       ToolTip="{Binding}"
                                                       Foreground="{TemplateBinding Foreground}"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#312E81"/>
                                                <Setter Property="Foreground" Value="#E2E8F0"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#1E1B4B"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <!-- Прокручиваемая нижняя часть -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="14,6,14,16">
                        <Button Content="📂  Открыть файл" Style="{StaticResource QuickBtn}"
                                Command="{Binding OpenDocumentFileCommand}" Margin="0,0,0,8"/>

                        <TextBlock Text="OFFICE WORKSPACE" Style="{StaticResource SideHeader}"/>
                        <ListBox ItemsSource="{Binding WorkspaceFiles}"
                                 SelectedItem="{Binding SelectedWorkspaceFile}"
                                 Background="#0D0D1A"
                                 BorderBrush="#1E1E35"
                                 BorderThickness="1"
                                 MaxHeight="165"
                                 Margin="0,0,0,6">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              Content="{Binding DisplayName}"
                                              Foreground="#CBD5E1"
                                              FontSize="12"
                                              ToolTip="{Binding FullPath}"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="8,5"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#312E81"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#1E1B4B"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                        <TextBlock Text="{Binding ChatResourceSummary}"
                                   Foreground="#64748B"
                                   FontSize="10"
                                   TextTrimming="CharacterEllipsis"
                                   Margin="2,0,0,6"/>
                        <Grid Margin="0,0,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="Все"
                                    Style="{StaticResource QuickBtn}"
                                    Command="{Binding SelectAllWorkspaceResourcesCommand}"
                                    Margin="0,0,4,0"/>
                            <Button Grid.Column="1" Content="Очистить"
                                    Style="{StaticResource QuickBtn}"
                                    Command="{Binding ClearWorkspaceResourcesCommand}"
                                    Margin="0,0,4,0"/>
                            <Button Grid.Column="2" Content="Сохранить"
                                    Style="{StaticResource QuickBtn}"
                                    Command="{Binding SaveSelectedChatResourcesCommand}"/>
                        </Grid>

                        <Separator Style="{StaticResource Sep}"/>

                        <!-- Chat sessions -->
                        <TextBlock Text="ЧАТЫ" Style="{StaticResource SideHeader}"/>
                        <Button Content="+  Новый чат" Style="{StaticResource QuickBtn}"
                                Command="{Binding NewChatCommand}" Margin="0,0,0,4"/>
                        <ListBox ItemsSource="{Binding ChatSessions}"
                                 SelectedItem="{Binding SelectedChatSession}"
                                 Background="#0D0D1A"
                                 BorderBrush="#1E1E35"
                                 BorderThickness="1"
                                 MaxHeight="150"
                                 Margin="0,0,0,6">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="{Binding DisplayTitle}"
                                                   Foreground="#CBD5E1"
                                                   FontSize="12"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Row="1"
                                                   Text="{Binding UpdatedAtStr}"
                                                   Foreground="#475569"
                                                   FontSize="10"/>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="8,5"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#312E81"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#1E1B4B"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>

                        <Separator Style="{StaticResource Sep}"/>

                        <!-- Document stats -->
                        <Border Background="#1A1A2E" CornerRadius="8" Padding="10,8" Margin="0,0,0,4">
                            <TextBlock Text="{Binding DocStats}" Foreground="#475569" FontSize="11"/>
                        </Border>

                        <Separator Style="{StaticResource Sep}"/>

                        <!-- Quick commands -->
                        <TextBlock Text="БЫСТРЫЕ КОМАНДЫ" Style="{StaticResource SideHeader}"/>
                        <Button Content="✓  Полная проверка" Style="{StaticResource QuickBtn}"
                                Command="{Binding QuickCheckAllCommand}" Margin="0,0,0,3"
                                IsEnabled="{Binding IsConnected}"/>
                        <Button Content="A  Шрифты и размеры" Style="{StaticResource QuickBtn}"
                                Command="{Binding QuickFixFontsCommand}" Margin="0,0,0,3"
                                IsEnabled="{Binding IsConnected}"/>
                        <Button Content="→  Отступы (1.25 см)" Style="{StaticResource QuickBtn}"
                                Command="{Binding QuickFixIndentsCommand}" Margin="0,0,0,3"
                                IsEnabled="{Binding IsConnected}"/>
                        <Button Content="↕  Межстрочный (1.5)" Style="{StaticResource QuickBtn}"
                                Command="{Binding QuickFixSpacingCommand}" Margin="0,0,0,3"
                                IsEnabled="{Binding IsConnected}"/>
                        <Button Content="≡  Выравнивание" Style="{StaticResource QuickBtn}"
                                Command="{Binding QuickFixAlignCommand}" Margin="0,0,0,3"
                                IsEnabled="{Binding IsConnected}"/>

                        <Separator Style="{StaticResource Sep}"/>

                        <!-- Pending operations -->
                        <TextBlock Text="ОЧЕРЕДЬ ОПЕРАЦИЙ" Style="{StaticResource SideHeader}"/>
                        <Border Background="#1A1A2E" CornerRadius="8" Padding="10,10"
                                Visibility="{Binding HasChanges, Converter={StaticResource BoolToVis}}">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <Border Background="#312E81" CornerRadius="10" Padding="7,2" Margin="0,0,7,0">
                                        <TextBlock Text="{Binding PendingCount}" Foreground="#A5B4FC"
                                                   FontSize="12" FontWeight="Bold"/>
                                    </Border>
                                    <TextBlock Text="операций" Foreground="#64748B" FontSize="12" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Button Content="Показать в чате" Style="{StaticResource PrimaryBtn}"
                                        Padding="8,7" FontSize="12"
                                        Command="{Binding ShowPreviewCommand}"/>
                            </StackPanel>
                        </Border>
                        <TextBlock Text="Нет операций" Foreground="#374151" FontSize="12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasChanges}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <Separator Style="{StaticResource Sep}"/>

                        <!-- Chat controls -->
                        <TextBlock Text="ЧАТ" Style="{StaticResource SideHeader}"/>
                        <Button Content="+  Новый чат" Style="{StaticResource QuickBtn}"
                                Command="{Binding ClearChatCommand}"/>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- ──────── CHAT AREA ──────── -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- Context -->
                    <RowDefinition Height="*"/>    <!-- Messages -->
                    <RowDefinition Height="Auto"/> <!-- Inline confirmation -->
                    <RowDefinition Height="Auto"/> <!-- Progress -->
                    <RowDefinition Height="Auto"/> <!-- Input -->
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#12121E" BorderBrush="#1E1E35" BorderThickness="0,0,0,1"
                        Padding="14,9">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding SelectedChatSession.DisplayTitle, TargetNullValue=Новый чат}"
                                       Foreground="#E2E8F0"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding ChatResourceSummary}"
                                       Foreground="#64748B"
                                       FontSize="11"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding SelectedDocument, TargetNullValue=Word не выбран}"
                                   Foreground="#64748B"
                                   FontSize="11"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0"
                                   TextTrimming="CharacterEllipsis"/>
                    </Grid>
                </Border>

                <!-- Messages -->
                <ScrollViewer x:Name="ChatScroll" Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              Padding="0,10,0,0">
                    <ItemsControl ItemsSource="{Binding ChatMessages}"
                                  ItemTemplateSelector="{StaticResource ChatSel}"
                                  Margin="0,0,0,10"/>
                </ScrollViewer>

                <!-- Inline operation confirmation -->
                <Border Grid.Row="2" Background="#12121E" BorderBrush="#1E1E35" BorderThickness="0,1,0,0"
                        Padding="12,10"
                        Visibility="{Binding HasChanges, Converter={StaticResource BoolToVis}}">
                    <Border Background="#172032" CornerRadius="8" Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="#312E81" CornerRadius="10" Padding="7,2" Margin="0,0,7,0">
                                        <TextBlock Text="{Binding PendingCount}" Foreground="#A5B4FC"
                                                   FontSize="12" FontWeight="Bold"/>
                                    </Border>
                                    <TextBlock Text="операций ожидают подтверждения"
                                               Foreground="#CBD5E1" FontSize="12"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <Button Grid.Column="1" Content="✕" Width="28" Height="26"
                                        Style="{StaticResource GhostBtn}"
                                        Padding="0" FontSize="12"
                                        Command="{Binding CancelPendingChangesCommand}"/>
                            </Grid>

                            <ScrollViewer Grid.Row="1" MaxHeight="210" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding PendingItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#1F2937" CornerRadius="6"
                                                    Padding="8" Margin="0,0,0,6">
                                                <StackPanel>
                                                    <CheckBox IsChecked="{Binding IsSelected}"
                                                              Content="{Binding DisplayText}"
                                                              Foreground="#E5E7EB"
                                                              FontSize="12"/>
                                                    <Expander Header="Скрипт"
                                                              Foreground="#94A3B8"
                                                              FontSize="11"
                                                              Margin="24,4,0,0">
                                                        <TextBlock Text="{Binding ScriptText}"
                                                                   Foreground="#CBD5E1"
                                                                   FontFamily="Cascadia Mono, Consolas, Courier New"
                                                                   FontSize="10"
                                                                   TextWrapping="Wrap"
                                                                   Margin="0,4,0,0"/>
                                                    </Expander>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>

                            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                                <Button Content="Отмена"
                                        Style="{StaticResource GhostBtn}"
                                        Padding="12,7" FontSize="12"
                                        Margin="0,0,8,0"
                                        Command="{Binding CancelPendingChangesCommand}"/>
                                <Button Content="Применить"
                                        Style="{StaticResource PrimaryBtn}"
                                        Padding="14,7" FontSize="12"
                                        Command="{Binding ApplyPendingChangesCommand}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Border>

                <!-- Progress area -->
                <Border Grid.Row="3" Background="#12121E" BorderBrush="#1E1E35" BorderThickness="0,1,0,0"
                        Padding="16,8"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVis}}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{Binding BusyText}" Foreground="#94A3B8" FontSize="12" Margin="0,0,0,5"/>
                            <ProgressBar Value="{Binding Progress}" Maximum="100" Height="3"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Foreground="#475569" FontSize="11" VerticalAlignment="Bottom" Margin="12,0,0,0">
                            <Run Text="{Binding Progress, StringFormat={}{0:F0}}"/>
                            <Run Text="%"/>
                        </TextBlock>
                    </Grid>
                </Border>

                <!-- Input area -->
                <Border Grid.Row="4" Background="#12121E" BorderBrush="#1E1E35" BorderThickness="0,1,0,0"
                        Padding="12,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0" x:Name="InputBox" MinHeight="38" MaxHeight="100"
                                 Text="{Binding UserInput, UpdateSourceTrigger=PropertyChanged}"
                                 TextWrapping="Wrap" AcceptsReturn="False"
                                 VerticalContentAlignment="Center"
                                 KeyDown="InputBox_KeyDown"
                                 Margin="0,0,10,0"/>

                        <StackPanel Grid.Column="1" Orientation="Vertical">
                            <Button Content="↑  Отправить"
                                    Padding="14,7" FontSize="12"
                                    Command="{Binding SendMessageCommand}">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                            <Button Content="✕  Отменить" Style="{StaticResource DangerBtn}"
                                    Padding="14,7" FontSize="12"
                                    Command="{Binding CancelOperationCommand}" Margin="0,5,0,0"
                                    Visibility="{Binding CanCancel, Converter={StaticResource BoolToVis}}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>
