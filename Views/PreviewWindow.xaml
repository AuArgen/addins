<Window x:Class="AIDocAssistant.Views.PreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Предпросмотр изменений" Height="560" Width="700"
        Background="#1E1E2E" Foreground="White"
        FontFamily="Segoe UI" FontSize="14"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#7C3AED"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#6D28D9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#DC2626"/>
        </Style>
        <Style x:Key="SecondaryBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
            <Setter Property="Background" Value="#374151"/>
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#2D2D3F" CornerRadius="8" Padding="14,10" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Будет изменено: " FontWeight="Bold"/>
                <TextBlock Text="{Binding SelectedCount}" FontWeight="Bold" Foreground="#7C3AED"/>
                <TextBlock Text=" операций" Foreground="#9CA3AF"/>
                <Button Content="Выбрать все" Style="{StaticResource SecondaryBtn}"
                        Margin="16,0,0,0" Padding="10,4" FontSize="12"
                        Command="{Binding SelectAllCommand}"/>
                <Button Content="Снять все" Style="{StaticResource SecondaryBtn}"
                        Margin="8,0,0,0" Padding="10,4" FontSize="12"
                        Command="{Binding CancelAllCommand}"/>
            </StackPanel>
        </Border>

        <!-- Список изменений -->
        <Border Grid.Row="1" Background="#2D2D3F" CornerRadius="8" Margin="0,0,0,10">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="8">
                <ItemsControl ItemsSource="{Binding Items}">
                    <ItemsControl.GroupStyle>
                        <GroupStyle>
                            <GroupStyle.HeaderTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" Foreground="#9CA3AF"
                                               FontSize="12" FontWeight="SemiBold"
                                               Margin="4,12,0,4"/>
                                </DataTemplate>
                            </GroupStyle.HeaderTemplate>
                        </GroupStyle>
                    </ItemsControl.GroupStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="8,6" Margin="2,2" CornerRadius="6"
                                    Background="#374151">
                                <StackPanel>
                                    <CheckBox IsChecked="{Binding IsSelected}"
                                              Content="{Binding DisplayText}"
                                              Foreground="White" FontSize="13"/>
                                    <Expander Header="Показать скрипт"
                                              Foreground="#CBD5E1"
                                              Margin="24,6,0,0"
                                              FontSize="12">
                                        <Border Background="#1F2937" CornerRadius="4" Padding="8" Margin="0,4,0,0">
                                            <TextBlock Text="{Binding ScriptText}"
                                                       Foreground="#D1D5DB"
                                                       FontFamily="Cascadia Mono, Consolas, Courier New"
                                                       FontSize="11"
                                                       TextWrapping="Wrap"/>
                                        </Border>
                                    </Expander>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Отменить всё" Style="{StaticResource DangerBtn}"
                    Margin="0,0,10,0"
                    Command="{Binding CancelAllCommand}"/>
            <Button Content="✅ Применить выбранное" Style="{StaticResource PrimaryBtn}"
                    Command="{Binding ApplySelectedCommand}"/>
        </StackPanel>
    </Grid>
</Window>
