<Window x:Class="AIDocAssistant.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="История взаимодействий" Height="660" Width="1000"
        MinHeight="500" MinWidth="700"
        Background="#0D0D1A" Foreground="#E2E8F0"
        FontFamily="Segoe UI" FontSize="13">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="HeaderTxt" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#475569"/>
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <ControlTemplate x:Key="BtnTpl" TargetType="Button">
            <Border Background="{TemplateBinding Background}" CornerRadius="6"
                    Padding="{TemplateBinding Padding}">
                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
            </ControlTemplate.Triggers>
        </ControlTemplate>

        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Background" Value="#7C3AED"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template" Value="{StaticResource BtnTpl}"/>
        </Style>
        <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource Btn}">
            <Setter Property="Background" Value="#7F1D1D"/>
            <Setter Property="Foreground" Value="#FCA5A5"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#1A1A2E"/>
            <Setter Property="Foreground" Value="#E2E8F0"/>
            <Setter Property="CaretBrush" Value="#7C3AED"/>
            <Setter Property="BorderBrush" Value="#2D2D4E"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,7"/>
        </Style>

        <!-- DataGrid стилдери BasedOn менен — ички WPF шаблондорун сактайт -->
        <Style x:Key="DgRowStyle" TargetType="DataGridRow"
               BasedOn="{StaticResource {x:Type DataGridRow}}">
            <Setter Property="Foreground" Value="#CBD5E1"/>
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#312E81"/>
                    <Setter Property="Foreground" Value="#E2E8F0"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1E1B4B"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="DgHeaderStyle" TargetType="DataGridColumnHeader"
               BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
            <Setter Property="Background" Value="#1A1A2E"/>
            <Setter Property="Foreground" Value="#64748B"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderBrush" Value="#1E1E35"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>

        <Style x:Key="DgCellStyle" TargetType="DataGridCell"
               BasedOn="{StaticResource {x:Type DataGridCell}}">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="BorderBrush" Value="Transparent"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="54"/>  <!-- Header -->
            <RowDefinition Height="*"/>   <!-- Content -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#12121E" BorderBrush="#1E1E35" BorderThickness="0,0,0,1">
            <Grid Margin="16,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0" Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                         MaxWidth="360" HorizontalAlignment="Left" VerticalAlignment="Center"
                         FontSize="12" Padding="10,6"/>
                <TextBlock Grid.Column="0" Text="Поиск по команде или документу..."
                           Foreground="#374151" FontSize="12" VerticalAlignment="Center" Margin="14,0,0,0"
                           IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding FilterText}" Value="">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <Button Grid.Column="1" Content="↻  Обновить" Style="{StaticResource Btn}"
                        Margin="0,0,8,0" Command="{Binding ReloadCommand}"
                        VerticalAlignment="Center"/>
                <Button Grid.Column="2" Content="✕  Очистить всё" Style="{StaticResource DangerBtn}"
                        Margin="0,0,8,0" Command="{Binding ClearHistoryCommand}"
                        VerticalAlignment="Center"/>
                <TextBlock Grid.Column="3" Foreground="#475569" FontSize="12" VerticalAlignment="Center">
                    <Run Text="{Binding Entries.Count, Mode=OneWay}"/>
                    <Run Text=" записей"/>
                </TextBlock>
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <!-- Divider -->
            <Border Grid.Column="1" Background="#1E1E35"/>

            <!-- Table -->
            <DataGrid Grid.Column="0"
                      ItemsSource="{Binding Entries}"
                      SelectedItem="{Binding Selected}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserReorderColumns="False"
                      SelectionMode="Single"
                      Background="#12121E"
                      Foreground="#CBD5E1"
                      BorderThickness="0"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#1E1E35"
                      RowBackground="#12121E"
                      AlternatingRowBackground="#161625"
                      RowStyle="{StaticResource DgRowStyle}"
                      ColumnHeaderStyle="{StaticResource DgHeaderStyle}"
                      CellStyle="{StaticResource DgCellStyle}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Время"    Binding="{Binding TimestampStr}"  Width="140"/>
                    <DataGridTextColumn Header="Документ" Binding="{Binding DocumentName}"  Width="170"/>
                    <DataGridTextColumn Header="Команда"  Binding="{Binding Command}"       Width="*"/>
                    <DataGridTextColumn Header="Статус"   Binding="{Binding StatusSummary}" Width="180"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Detail panel -->
            <Grid Grid.Column="2" Background="#12121E">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" BorderBrush="#1E1E35" BorderThickness="0,0,0,1" Padding="12,8">
                    <TextBlock Text="ДЕТАЛИ ЗАПИСИ" Foreground="#475569" FontSize="10" FontWeight="SemiBold"/>
                </Border>

                <ScrollViewer Grid.Row="1" Padding="12" VerticalScrollBarVisibility="Auto">
                    <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap"
                               Foreground="#94A3B8" FontSize="12" FontFamily="Cascadia Mono, Consolas, Courier New"
                               LineHeight="18"/>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</Window>
