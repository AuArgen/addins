<Window x:Class="AIDocAssistant.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:AIDocAssistant.Models"
        Title="Настройки" Height="540" Width="520"
        Background="#1E1E2E" Foreground="White"
        FontFamily="Segoe UI" FontSize="14"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize" MinHeight="500">

    <Window.Resources>
        <Style TargetType="Label">
            <Setter Property="Foreground" Value="#D1D5DB"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#2D2D3F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#4B5563"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#2D2D3F"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#4B5563"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>
        <Style x:Key="PrimaryBtn" TargetType="Button">
            <Setter Property="Background" Value="#7C3AED"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,9"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#6D28D9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
            <TextBlock Text="Настройки AI Document Assistant"
                       FontSize="18" FontWeight="Bold" Margin="0,0,0,20"/>

            <Label Content="AI-провайдер"/>
            <ComboBox ItemsSource="{Binding Providers}"
                      SelectedItem="{Binding SelectedProvider}"/>

            <Label Content="API-ключ (сохраняется в Windows Credential Manager)"/>
            <PasswordBox x:Name="ApiKeyBox"
                         Background="#2D2D3F" Foreground="White"
                         BorderBrush="#4B5563" Padding="8,6" Margin="0,0,0,14"
                         PasswordChanged="ApiKeyBox_PasswordChanged"/>

            <Label Content="Модель"/>
            <ComboBox ItemsSource="{Binding AvailableModels}"
                      SelectedItem="{Binding SelectedModel}"/>

            <Label Content="Лимит токенов на запрос"/>
            <TextBox Text="{Binding MaxTokens, UpdateSourceTrigger=PropertyChanged}"/>

            <CheckBox Content="Автоматический backup перед изменениями"
                      IsChecked="{Binding AutoBackup}"
                      Foreground="White" Margin="0,0,0,10"/>

            <CheckBox Content="Авто-анализ при подключении к Word"
                      IsChecked="{Binding AutoAnalyzeOnConnect}"
                      Foreground="#A78BFA" FontWeight="SemiBold" Margin="0,0,0,14"/>

            <Label Content="Размер чанка (абзацев за один запрос к AI)"/>
            <TextBox Text="{Binding ChunkSize, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
            </ScrollViewer>

            <Button Grid.Row="1" Content="Сохранить" Style="{StaticResource PrimaryBtn}"
                    HorizontalAlignment="Right" Margin="0,12,0,0"
                    Command="{Binding SaveCommand}"/>
        </Grid>
    </Border>
</Window>
